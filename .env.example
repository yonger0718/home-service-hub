# ==============================================================================
# Home Inventory System - Environment Configuration Template
# ==============================================================================

# --- 1. 資料庫 (PostgreSQL) ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432
DB_HOST=localhost
INVENTORY_DB=inventory_db
ACCOUNTING_DB=accounting_db
STOCK_DB=stock_portfolio_db

# --- 2. 基礎設施 (Infrastructure) ---
GRAFANA_ADMIN_PASSWORD=admin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672
INFRA_HOST=localhost

# --- 3. 庫存管理服務 (Java: inventory-item-service) ---
INVENTORY_ITEM_SERVICE_HOST=localhost
INVENTORY_ITEM_SERVICE_PORT=8080
SPRING_APPLICATION_NAME=inventory-item-service

# --- 4. 會計管理服務 (Python: accounting-service) ---
ACCOUNTING_SERVICE_HOST=localhost
ACCOUNTING_SERVICE_PORT=8000
OTEL_SERVICE_NAME_ACCOUNTING=accounting-service

# --- 4.5 投資組合服務 (Python: stock-portfolio-service) ---
STOCK_SERVICE_HOST=localhost
STOCK_SERVICE_PORT=8001
OTEL_SERVICE_NAME_STOCK=stock-portfolio-service

# --- 5. 前端與連線設定 (Frontend & CORS) ---
FRONTEND_PORT=4200
FRONTEND_API_URL=/api
ALLOWED_HOSTS=localhost,mac-mini.local
ALLOWED_ORIGINS=http://localhost:4200

# --- 6. 可觀測性 (OpenTelemetry) ---
# Java 使用 HTTP (4318), Python 使用 gRPC (4317)
OTEL_COLLECTOR_ENDPOINT_HTTP=http://localhost:4318
OTEL_COLLECTOR_ENDPOINT_GRPC=http://localhost:4317
TWSE_SSL_VERIFY=false

# --- 7. 投資組合排程與重算開關 (Stock-portfolio service toggles) ---
# Set to "false" to disable the FastAPI background recalc chain after CSV import.
# The chain refreshes symbol_map, dividends, and networth snapshots; the
# manual POST /api/portfolio/imports/recalc endpoint still works regardless.
POST_IMPORT_RECALC_ENABLED=true
